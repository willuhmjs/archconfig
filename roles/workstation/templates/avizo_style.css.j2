#avizo {
  background: rgba(15, 15, 15, 0.90);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.5);
}

#avizo image {
  opacity: 1.0;
  color: #cdd6f4;
}

#avizo progress {
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.15);
}

#avizo progress trough {
  border-radius: 4px;
  background: rgba(0, 0, 0, 0.4);
}
