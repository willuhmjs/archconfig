general {
    lock_cmd = pidof hyprlock || hyprlock       # dbus/sysd lock command (loginctl lock-session)
    before_sleep_cmd = loginctl lock-session    # lock before suspend.
    after_sleep_cmd = hyprctl dispatch dpms on  # to avoid having to press a key twice to turn on the display.
}

listener {
    timeout = 150                                # 2.5 mins
    on-timeout = brightnessctl set 10%           # set monitor backlight to 10%
    on-resume = brightnessctl set 100%           # restore monitor backlight
}

# turn off keyboard backlight, comment out this section if you dont have a keyboard backlight
listener { 
    timeout = 150                                          # 2.5 mins
    on-timeout = brightnessctl -sd rgb:kbd_backlight set 0 # turn off keyboard backlight.
    on-resume = brightnessctl -rd rgb:kbd_backlight        # turn on keyboard backlight.
}

listener {
    timeout = 300                                # 5 mins
    on-timeout = loginctl lock-session           # lock screen
}

listener {
    timeout = 330                                # 5.5 mins
    on-timeout = hyprctl dispatch dpms off       # turn off screen
    on-resume = hyprctl dispatch dpms on         # turn on screen
}

listener {
    timeout = 1800                               # 30 mins
    on-timeout = systemctl suspend               # suspend pc
}
